# --- Base de datos (Railway plugin de PostgreSQL inyecta DATABASE_URL) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/papilomed

# En local con Postgres sin SSL deja PGSSL=false.
# En Railway normalmente NO se necesita (usa proxy interno); si tu conexión externa
# exige SSL, pon PGSSL=true.
PGSSL=false

# --- Servidor ---
PORT=3000
# development | production  (en production la cookie usa Secure)
NODE_ENV=development

# --- Auth ---
# Cadena larga y aleatoria. Genera una con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
# Duración de la sesión (formato de jsonwebtoken: 7d, 24h, etc.)
JWT_EXPIRES_IN=7d

# --- Seed: usuario ADMIN (Botikit) ---
SEED_ADMIN_EMAIL=admin@botikit.com
SEED_ADMIN_PASSWORD=cambia-esta-password
SEED_ADMIN_NOMBRE=Administrador Botikit

# --- Seed: usuario CLIENTE (Papilomed) ---
SEED_CLIENTE_EMAIL=cliente@papilomed.com
SEED_CLIENTE_PASSWORD=cambia-esta-password
SEED_CLIENTE_NOMBRE=Papilomed
